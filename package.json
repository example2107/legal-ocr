{
  "name": "legal-ocr",
  "version": "1.0.1",
  "private": true,
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jscpd": "^4.0.8",
    "madge": "^6.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "cross-env CI=false react-scripts build",
    "test": "react-scripts test",
    "test:ci": "cross-env CI=true react-scripts test --watchAll=false",
    "coverage": "cross-env CI=true react-scripts test --watchAll=false --coverage",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:strict": "eslint \"src/**/*.{js,jsx}\" --max-warnings=0",
    "deps:check": "madge --circular --extensions js,jsx src",
    "dupcheck": "jscpd --config .jscpd.json"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
